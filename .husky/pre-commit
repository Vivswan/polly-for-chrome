#!/bin/sh

if [ ! -d node_modules ]; then
    echo "Dependencies are not installed. Run 'bun install' before committing."
    exit 1
fi

bunx lint-staged

bun run lint:actions

bun run lint

bun run typecheck

# Run tests once if test files exist
if find tests src -type f \( -name "*.test.*" -o -name "*.spec.*" \) | grep -q .; then
    bun run test:run
fi
